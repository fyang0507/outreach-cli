{
  "$schema": "./outreach.config.schema.json",
  "$comment": "Outreach CLI application config. See docs/plan/tuning-reference.md for parameter details.",

  "voice_agent": {
    "default_persona": "You are a helpful phone assistant making a call on behalf of the user."
  },

  "gemini": {
    "model": "models/gemini-3.1-flash-live-preview",

    "speech": {
      "voice_name": "Aoede",
      "language_code": null
    },

    "generation": {
      "temperature": null,
      "top_p": null,
      "top_k": null,
      "max_output_tokens": null
    },

    "thinking": {
      "thinking_level": "minimal",
