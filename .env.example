TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Auth mode A: Account Auth Token
TWILIO_AUTH_TOKEN=your_auth_token

# Auth mode B: API key auth for direct REST requests. Keep TWILIO_AUTH_TOKEN set as well,
# because `outreach call init` uses it to verify Twilio webhook signatures.
# TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_API_KEY_SECRET=your_api_key_secret

# Outbound caller ID — set to your personal number (must be verified in Twilio)
OUTREACH_DEFAULT_FROM=+15551234567


# Google Generative AI API Key
GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_api_key

# Application behavior config (model, voice, VAD, system prompt, etc.)
# lives in outreach.config.json — not here.