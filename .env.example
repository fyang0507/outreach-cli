TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Auth mode A: Account Auth Token
TWILIO_AUTH_TOKEN=your_auth_token

# Auth mode B: API key auth for direct REST requests. Keep TWILIO_AUTH_TOKEN set as well,
# because `outreach call init` uses it to verify Twilio webhook signatures.
# TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_API_KEY_SECRET=your_api_key_secret

# Caller ID shown when reaching out to others — your personal number (must be verified in Twilio)
PERSONAL_CALLER_ID=+15551234567

# Twilio-owned number. Used as caller ID for `call place --from-twilio`/`--call-operator`
# — e.g. calling your own number, where the personal caller ID can't be used
# because it would equal the destination.
TWILIO_DEFAULT_FROM_NUMBER=+15550000000


# Google Generative AI API Key
GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_api_key

# Gmail API OAuth credentials
GMAIL_CLIENT_ID=<from downloaded JSON>
GMAIL_CLIENT_SECRET=<from downloaded JSON>

# Application behavior config (model, voice, VAD, system prompt, etc.)
# lives in outreach.config.json — not here.